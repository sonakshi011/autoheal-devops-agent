# ─────────────────────────────────────────────────────────────────
# AutoHeal DevOps Agent — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────

# ── Gemini API ────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini model selection (optional — these are the recommended defaults)
# Change here to switch models project-wide without touching any Python files.
# Free-tier default  : gemini-2.5-flash   (fast, generous free quota)
# Complex analysis   : gemini-2.5-pro     (deeper reasoning, lower quota)
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
GEMINI_COMPLEX_MODEL=gemini-2.5-pro

# ── App settings ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── GitHub integration (for local script testing) ─────────────────
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=owner/repo

# ── Observability (Phase 5) ───────────────────────────────────────
# Grafana admin password for the local compose stack.
# Default is 'autoheal' if not set. Change before any shared deployment.
GRAFANA_ADMIN_PASSWORD=autoheal
