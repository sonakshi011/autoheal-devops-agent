# API Key for Gemini API (Required)
# Get yours from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# App settings
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# CI/CD and GitHub settings (for local script testing)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPOSITORY=owner/repo
